@using Microsoft.AspNetCore.Components.Web

@if (IsOpen)
{
    <div class="fixed inset-0 z-[200] flex items-center justify-center bg-black/50">
        <div class="bg-white rounded-lg shadow-lg w-96 p-6 animate-fade-in">
            <h2 class="text-lg font-bold mb-2 text-gray-800">読み込むページを指定</h2>
            <div class="mb-1 text-sm text-gray-700">
                読み込むページを入力してください（全 @TotalPages ページ）。
            </div>
            <div class="mb-3 text-xs text-gray-500">
                例：<span class="font-mono bg-gray-100 px-1 rounded">3</span>（単ページ）、
                <span class="font-mono bg-gray-100 px-1 rounded">1,3,5</span>（複数指定）、
                <span class="font-mono bg-gray-100 px-1 rounded">2-8</span>（範囲）、
                <span class="font-mono bg-gray-100 px-1 rounded">1-3,7,10-12</span>（混合）
            </div>
            <input type="text"
                class="w-full border border-gray-300 rounded px-3 py-2 mb-1 focus:outline-none focus:ring-2 focus:ring-blue-400 font-mono"
                @bind="pageInput"
                @bind:event="oninput"
                @onkeyup="OnKeyUp"
                placeholder="例: 1-3,7,10"
                autofocus />
            @if (parsedPages != null && parsedPages.Count > 0 && errorMessage == null)
            {
                <div class="text-blue-700 text-xs mb-2">
                    @parsedPages.Count ページ選択中：@SummaryText()
                </div>
            }
            @if (errorMessage != null)
            {
                <div class="text-red-600 text-xs mb-2">@errorMessage</div>
            }
            <div class="flex justify-end gap-2 mt-3">
                <button type="button"
                    class="px-4 py-1 rounded bg-gray-200 text-gray-700 hover:bg-gray-300 transition"
                    @onclick="Cancel">
                    キャンセル
                </button>
                <button
                    class="px-4 py-1 rounded bg-blue-600 text-white hover:bg-blue-700 transition disabled:opacity-50"
                    @onclick="Submit"
                    disabled="@(parsedPages == null || parsedPages.Count == 0 || errorMessage != null)">
                    OK
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public int TotalPages { get; set; } = 1;
    /// <summary>
    /// 選択されたページ番号リスト（1始まり、昇順）。キャンセル時は null。
    /// </summary>
    [Parameter] public EventCallback<List<int>?> OnClose { get; set; }

    private string pageInput = "";
    private string? errorMessage;
    private List<int>? parsedPages;

    protected override void OnParametersSet()
    {
        if (IsOpen)
        {
            pageInput = "";
            errorMessage = null;
            parsedPages = null;
        }
    }

    // 入力値が変わるたびにリアルタイムでパース
    private string PageInput
    {
        get => pageInput;
        set
        {
            pageInput = value;
            TryParse();
        }
    }

    private void TryParse()
    {
        if (string.IsNullOrWhiteSpace(pageInput))
        {
            parsedPages = null;
            errorMessage = null;
            return;
        }

        var result = new HashSet<int>();
        var tokens = pageInput.Split(',', StringSplitOptions.RemoveEmptyEntries);
        foreach (var token in tokens)
        {
            var t = token.Trim();
            if (string.IsNullOrEmpty(t)) continue;

            // 範囲: "10-15" または "10～15"
            var dashIdx = t.IndexOfAny(new[] { '-', '～' }, 1); // 先頭マイナスを除く
            if (dashIdx > 0)
            {
                var left = t[..dashIdx].Trim();
                var right = t[(dashIdx + 1)..].Trim();
                if (int.TryParse(left, out int from) && int.TryParse(right, out int to))
                {
                    if (from < 1 || to < 1 || from > TotalPages || to > TotalPages)
                    {
                        errorMessage = $"ページ番号は 1〜{TotalPages} の範囲で指定してください。（入力: {t}）";
                        parsedPages = null;
                        return;
                    }
                    if (from > to)
                    {
                        errorMessage = $"範囲の開始が終了より大きいです。（入力: {t}）";
                        parsedPages = null;
                        return;
                    }
                    for (int p = from; p <= to; p++) result.Add(p);
                }
                else
                {
                    errorMessage = $"範囲の指定が正しくありません。（入力: {t}）";
                    parsedPages = null;
                    return;
                }
            }
            else
            {
                // 単ページ
                if (int.TryParse(t, out int page))
                {
                    if (page < 1 || page > TotalPages)
                    {
                        errorMessage = $"ページ番号は 1〜{TotalPages} の範囲で指定してください。（入力: {t}）";
                        parsedPages = null;
                        return;
                    }
                    result.Add(page);
                }
                else
                {
                    errorMessage = $"ページ番号の形式が正しくありません。（入力: {t}）";
                    parsedPages = null;
                    return;
                }
            }
        }

        errorMessage = null;
        parsedPages = result.OrderBy(x => x).ToList();
    }

    private string SummaryText()
    {
        if (parsedPages == null || parsedPages.Count == 0) return "";
        const int maxShow = 8;
        var shown = parsedPages.Take(maxShow).Select(p => p.ToString());
        var text = string.Join(", ", shown);
        if (parsedPages.Count > maxShow) text += $" …（+{parsedPages.Count - maxShow}ページ）";
        return text;
    }

    private async Task Submit()
    {
        TryParse();
        if (errorMessage != null || parsedPages == null || parsedPages.Count == 0) return;
        await OnClose.InvokeAsync(parsedPages);
    }

    private async Task Cancel()
    {
        errorMessage = null;
        parsedPages = null;
        await OnClose.InvokeAsync(null);
    }

    private async Task OnKeyUp(KeyboardEventArgs e)
    {
        // oninput で pageInput が更新されるが、bind:event="oninput" で直接フィールドに
        // 書き込まれるため、こちらでも TryParse を呼ぶ
        TryParse();
        if (e.Key == "Enter") await Submit();
        if (e.Key == "Escape") await Cancel();
    }
}
